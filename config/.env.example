# ============================================
# xSushi Ratio Tracker — Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp config/.env.example config/.env

# PostgreSQL connection string (required).
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql+asyncpg://pool_user:your_password@postgres:5432/sushi_db

# Telegram bot token (required for bot functionality).
# Get one from @BotFather: https://t.me/BotFather
BOT_TOKEN=your_bot_token_here

# Ethplorer API key (optional, defaults to "freekey").
# Get one at: https://ethplorer.io/
ETHPLORER_KEY=your_ethplorer_key_here
