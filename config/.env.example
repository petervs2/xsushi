# ============================================
# xSushi Ratio Tracker — Environment Variables
# ============================================
# Copy this file to .env and fill in your values:
#   cp config/.env.example config/.env

# SQLite database file path (default: ./data/xsushi.db).
# The data/ directory is bind-mounted as /app/data in docker-compose.yml
# so the database file persists outside the container.
DATABASE_URL=sqlite+aiosqlite:///./data/xsushi.db

# Telegram bot token (required for bot functionality).
# Get one from @BotFather: https://t.me/BotFather
BOT_TOKEN=your_bot_token_here

# Ethplorer API key (optional, defaults to "freekey").
# Get one at: https://ethplorer.io/
ETHPLORER_KEY=your_ethplorer_key_here
